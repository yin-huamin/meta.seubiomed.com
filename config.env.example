# 宏基因组文献追踪系统 - 配置文件
# 复制为 config.env 并填写你的 API Key

# ── LLM 配置（必填）──
# 支持任何 OpenAI 兼容接口
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# ── NCBI 配置（可选，加速）──
# 从 https://www.ncbi.nlm.nih.gov/account/ 申请免费 API Key
NCBI_API_KEY=

# ── 其他 ──
LLM_TIMEOUT=60
LLM_DELAY=1.5
