# 宏基因组文献追踪系统 - 配置文件模板
# 复制此文件为 config.env 并填写相应的值
# 不要将 config.env 上传到 GitHub（已加入 .gitignore）

# ──────────────────────────── LLM 配置（必填）────────────────────────────
# 支持任何 OpenAI 兼容接口（OpenAI / DeepSeek / 本地 Ollama 等）

# API 地址（OpenAI 兼容格式）
# - OpenAI: https://api.openai.com/v1/chat/completions
# - DeepSeek: https://api.deepseek.com/v1/chat/completions
# - 本地 Ollama: http://localhost:11434/v1/chat/completions
LLM_API_URL=https://api.openai.com/v1/chat/completions

# API 密钥（从服务商获取）
LLM_API_KEY=sk-your-key-here

# 模型名称（根据服务商填写）
# - OpenAI: gpt-4o-mini, gpt-4o, gpt-4-turbo
# - DeepSeek: deepseek-chat, deepseek-reasoner
# - Ollama: qwen2.5:7b, llama3.1:8b
LLM_MODEL=gpt-4o-mini


# ──────────────────────────── NCBI 配置（可选）────────────────────────────
# 从 https://www.ncbi.nlm.nih.gov/account/ 申请免费 API Key（加速抓取）
NCBI_API_KEY=

# 联系邮箱（NCBI 建议提供，便于他们联系你）
# 如果使用 NCBI API，建议填写真实邮箱
NCBI_EMAIL=your-email@example.com


# ──────────────────────────── 其他配置 ─────────────────────────────
# LLM 请求超时时间（秒）
LLM_TIMEOUT=60

# 每篇论文之间的延迟（秒），避免触发速率限制
LLM_DELAY=1.5


# ──────────────────────────── 配置示例 ─────────────────────────────
# DeepSeek 配置示例：
# LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# LLM_API_KEY=sk-xxxxxxxxx
# LLM_MODEL=deepseek-chat

# 本地 Ollama 配置示例（免费，需先运行 ollama serve）：
# LLM_API_URL=http://localhost:11434/v1/chat/completions
# LLM_API_KEY=not-needed
# LLM_MODEL=qwen2.5:7b
